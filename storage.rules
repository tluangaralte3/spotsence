rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ── Helper ──────────────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    // ── Community photos uploaded from place detail sheet ────────────────────
    // Path: community_photos/{collection}/{placeId}/{userId}_{timestamp}.{ext}
    match /community_photos/{collection}/{placeId}/{fileName} {
      allow read: if true;
      allow create: if isAuth()
                    && request.resource.size < 10 * 1024 * 1024   // max 10 MB
                    && request.resource.contentType.matches('image/.*');
      allow delete: if isAuth()
                    && fileName.matches(request.auth.uid + '_.*');
    }

    // ── Profile avatars ──────────────────────────────────────────────────────
    match /avatars/{userId}/{fileName} {
      allow read: if true;
      allow write: if isAuth() && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Admin listing images (admin upload via app) ─────────────────────────
    match /admin_listings/{collection}/{fileName} {
      allow read: if true;
      allow write: if isAuth()
                   && request.resource.size < 15 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Spot / listing hero images (admin upload only) ────────────────────────
    match /spots/{fileName} {
      allow read: if true;
      allow write: if isAuth();
    }

    match /listings/{collection}/{fileName} {
      allow read: if true;
      allow write: if isAuth();
    }

    // ── Bucket list banners ──────────────────────────────────────────────────
    match /bucket_list_banners/{fileName} {
      allow read: if true;
      allow write: if isAuth();
    }

    // ── Dare banners ─────────────────────────────────────────────────────────
    match /dare_banners/{fileName} {
      allow read: if true;
      allow create: if isAuth()
                    && request.resource.size < 10 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
      allow delete: if isAuth()
                    && fileName.matches('dare_' + request.auth.uid + '_.*');
    }

    // ── Dare proof submissions ────────────────────────────────────────────────
    match /dare_proofs/{fileName} {
      allow read: if isAuth();
      allow create: if isAuth()
                    && request.resource.size < 15 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
    }

    // ── Dare challenge sample photos ─────────────────────────────────────────
    match /challenge_samples/{fileName} {
      allow read: if true;
      allow create: if isAuth()
                    && request.resource.size < 10 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
      allow delete: if isAuth()
                    && fileName.matches('challenge_' + request.auth.uid + '_.*');
    }

    // ── Home banner images (admin upload) ────────────────────────────────────
    match /banners/{fileName} {
      allow read: if true;
      allow write: if isAuth()
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

  }
}
