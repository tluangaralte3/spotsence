rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isUser(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isSuperAdmin() {
      return isAuth() && request.auth.token.superAdmin == true;
    }

    // ── Users ───────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isUser(userId);
      allow update: if isUser(userId);
      allow delete: if isUser(userId);

      // XP activity log — user can read and create their own events
      match /xpEvents/{eventId} {
        allow read: if isUser(userId);
        allow create: if isUser(userId);
      }
    }

    // ── Listings (read-only for users, write via admin/functions) ───────────

    match /spots/{docId} {
      allow read: if true;
      allow write: if isAuth();

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isAuth();
        allow update, delete: if isAuth() && request.auth.uid == resource.data.userId;
      }

      match /communityPhotos/{photoId} {
        allow read: if true;
        allow create: if isAuth();
        allow delete: if isAuth() && request.auth.uid == resource.data.userId;
      }
    }

    match /restaurants/{docId} {
      allow read: if true;
      allow write: if isAuth();

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isAuth();
        allow update, delete: if isAuth() && request.auth.uid == resource.data.userId;
      }

      match /communityPhotos/{photoId} {
        allow read: if true;
        allow create: if isAuth();
        allow delete: if isAuth() && request.auth.uid == resource.data.userId;
      }
    }

    match /cafes/{docId} {
      allow read: if true;
      allow write: if isAuth();

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isAuth();
        allow update, delete: if isAuth() && request.auth.uid == resource.data.userId;
      }

      match /communityPhotos/{photoId} {
        allow read: if true;
        allow create: if isAuth();
        allow delete: if isAuth() && request.auth.uid == resource.data.userId;
      }
    }

    match /accommodations/{docId} {
      allow read: if true;
      allow write: if isAuth();

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isAuth();
        allow update, delete: if isAuth() && request.auth.uid == resource.data.userId;
      }
    }

    match /homestays/{docId} {
      allow read: if true;
      allow write: if isAuth();

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isAuth();
        allow update, delete: if isAuth() && request.auth.uid == resource.data.userId;
      }
    }

    match /adventureSpots/{docId} {
      allow read: if true;
      allow write: if isAuth();

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isAuth();
        allow update, delete: if isAuth() && request.auth.uid == resource.data.userId;
      }
    }

    match /shoppingAreas/{docId} {
      allow read: if true;
      allow write: if isAuth();

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isAuth();
        allow update, delete: if isAuth() && request.auth.uid == resource.data.userId;
      }
    }

    match /events/{docId} {
      allow read: if true;
      allow write: if isAuth();
    }

    // ── Reviews ─────────────────────────────────────────────────────────────

    match /reviews/{docId} {
      allow read: if true;
      allow create: if isAuth();
      allow update, delete: if isAuth() && request.auth.uid == resource.data.userId;
    }

    // ── Bookmarks ───────────────────────────────────────────────────────────

    match /bookmarks/{docId} {
      allow read, write: if isAuth() && request.auth.uid == resource.data.userId;
      allow create: if isAuth();
    }

    // ── Bucket Lists ─────────────────────────────────────────────────────────

    match /bucketLists/{listId} {
      // Public lists readable by all; private only by host + members.
      // resource == null guard prevents errors when the doc doesn't exist yet.
      allow read: if resource == null
                  || resource.data.visibility == 'public'
                  || (isAuth() && (
                       request.auth.uid == resource.data.hostId
                       || request.auth.uid in resource.data.memberIds
                     ));

      // Any authenticated user can create a bucket list
      allow create: if isAuth();

      // Host can update anything; approved members can update (check-off items)
      allow update: if isAuth()
                    && (request.auth.uid == resource.data.hostId
                        || request.auth.uid in resource.data.memberIds);

      // Only host can delete
      allow delete: if isAuth() && request.auth.uid == resource.data.hostId;
    }

    // ── Place Rankings (leaderboard aggregation) ─────────────────────────────

    match /place_rankings/{category} {
      allow read: if true;
      allow write: if isAuth();
    }

    // ── Place Leaderboard (per-place aggregated rating for leaderboard screen)

    match /place_leaderboard/{placeId} {
      // Anyone can read — leaderboard is public
      allow read: if true;
      // Authenticated users write after submitting a review
      allow write: if isAuth();
    }

    // ── Global Reviews (cross-collection review feed) ─────────────────────────

    match /global_reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuth();
      allow update, delete: if isAuth() && request.auth.uid == resource.data.userId;
    }

    // ── Dilemmas (community voting posts) ────────────────────────────────────

    match /dilemmas/{dilemmaId} {
      // Anyone can read dilemmas
      allow read: if true;
      // Authenticated users can create dilemmas
      allow create: if isAuth();
      // Authenticated users can update (voting updates votesA/votesB arrays)
      allow update: if isAuth();
      // Only the author can delete their own dilemma
      allow delete: if isAuth() && request.auth.uid == resource.data.authorId;
    }

    // ── Admin (app_admins collection) ────────────────────────────────────────

    match /app_admins/{adminId} {
      // Super admin can read/write their own doc; other admins can read their own
      allow read: if isSuperAdmin() || isUser(adminId);
      allow write: if isSuperAdmin();

      // Activity log — super admin can read/write
      match /activityLog/{logId} {
        allow read, write: if isSuperAdmin();
      }
    }

    // ── Analytics snapshot ───────────────────────────────────────────────────

    match /app_analytics/{docId} {
      allow read: if isSuperAdmin();
      allow write: if isSuperAdmin();
    }

    // ── Tour packages ────────────────────────────────────────────────────────

    match /tour_packages/{docId} {
      allow read: if true;
      allow write: if isSuperAdmin();

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isAuth();
        allow update, delete: if isAuth() && request.auth.uid == resource.data.userId;
      }
    }

    // ── Ventures (adventure packages created via admin form) ─────────────────

    match /ventures/{docId} {
      allow read: if true;
      allow write: if isSuperAdmin();

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isAuth();
        allow update, delete: if isAuth() && request.auth.uid == resource.data.userId;
      }

      // Registrations sub-collection: users can create their own
      match /registrations/{regId} {
        allow read: if isSuperAdmin() || (isAuth() && request.auth.uid == resource.data.userId);
        allow create: if isAuth();
        allow update: if isSuperAdmin();
        allow delete: if isSuperAdmin();
      }

      // Feedback sub-collection
      match /feedback/{fbId} {
        allow read: if true;
        allow create: if isAuth();
        allow update, delete: if isAuth() && request.auth.uid == resource.data.userId;
      }
    }

    // ── Feedback collectionGroup (required for admin collectionGroup query) ──

    match /{path=**}/feedback/{fbId} {
      allow read: if true;
    }

    // ── Bookings (venture booking requests) ──────────────────────────────────

    match /bookings/{bookingId} {
      // Users can read and create their own bookings
      allow read: if isAuth() && (request.auth.uid == resource.data.userId || isSuperAdmin());
      allow create: if isAuth() && request.auth.uid == request.resource.data.userId;
      // Admin can update anything; users can only flip hasFeedback on their own booking
      allow update: if isSuperAdmin()
        || (isAuth()
            && request.auth.uid == resource.data.userId
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['hasFeedback', 'updatedAt']));
      allow delete: if isSuperAdmin();
    }

    // ── Community posts ──────────────────────────────────────────────────────

    match /community_posts/{docId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth() && (request.auth.uid == resource.data.authorId || isSuperAdmin());
      allow delete: if isAuth() && (request.auth.uid == resource.data.authorId || isSuperAdmin());
    }

    // ── Hotels ───────────────────────────────────────────────────────────────

    match /hotels/{docId} {
      allow read: if true;
      allow write: if isSuperAdmin();

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isAuth();
        allow update, delete: if isAuth() && request.auth.uid == resource.data.userId;
      }
    }
    // ── Home Banners ─────────────────────────────────────────────────────────

    match /home_banners/{bannerId} {
      // Any user (even unauthenticated) can read active banners for the home screen
      allow read: if true;
      // Only super admins can create / update / delete banners
      allow write: if isSuperAdmin();
    }

    // ── App Config (used for section visibility flags etc.) ──────────────────

    match /app_config/{docId} {
      // Any user can read config (needed to hide/show home sections)
      allow read: if true;
      // Only super admins can write config
      allow write: if isSuperAdmin();
    }

  }
}
